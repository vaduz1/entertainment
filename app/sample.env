# SMTP/IMAP Credentials
EMAIL_USER=mobile@
EMAIL_PASS=
IMAP_SERVER=imapdisney-pms.com
# Subscription Senders
NETFLIX_SENDER=info@://netflix.com
DISNEY_SENDER=disneyplus.com
HBO_SENDER=support@max.com
PARAMOUNT_SENDER=allaccess@://paramountplus.com
MEGOGO=account.megogo.net
# Extraction Rules (Regex)
# Example: Finds text after 'Total:' or 'Your plan:'
NETFLIX_RULE=r"Plan: (.+?)(?=\n)"
DISNEY_RULE=r"15 minutes.*?(\d{6})"
HBO_RULE=r"Next bill date: (.+?)(?=\.)"


# Regex Patterns for each service
REGEX_CHATGPT=\b\d{6}\b
REGEX_NETFLIX=Your Netflix code is.*?(\d{6})
#REGEX_DISNEY=It will expire in 15.*?(\d{6})
REGEX_DISNEY=It will expire in 15.*?(?<!#)(\d{6})
REGEX_PARAMOUNT=code.*?(\d{6})
REGEX_DISCOVERY=code.*?(\d{6})
REGEX_HBO=code.*?(\d{6})
REGEX_MEGOGO=MEGOGO.*?(\d{6})
REGEX_SKY=g this access code.*?(?<!#)(\d{6})

